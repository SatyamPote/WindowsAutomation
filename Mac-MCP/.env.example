# mac-mcp environment variables

# Screenshot backend: auto | quartz | mss | pillow
MAC_MCP_SCREENSHOT_BACKEND=auto

# Screenshot scale factor (0.1 - 1.0). Lower on HiDPI/Retina to stay under 1MB.
MAC_MCP_SCREENSHOT_SCALE=1.0

# Set to 1 to log per-stage timing for Snapshot tool
MAC_MCP_PROFILE_SNAPSHOT=

# Set to 1 to enable verbose debug logging
MAC_MCP_DEBUG=false

# Set to false to disable anonymous telemetry
ANONYMIZED_TELEMETRY=true
